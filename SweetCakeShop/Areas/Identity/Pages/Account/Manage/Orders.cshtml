@page
@model SweetCakeShop.Areas.Identity.Pages.Account.Manage.OrdersModel
@using SweetCakeShop.Models
@using System.Globalization
@{
    ViewData["Title"] = "Lịch sử mua hàng";
}

<div class="container mt-4">
    <h2 class="mb-4" style="color: #d81b60; font-weight: bold;">
        <i class="bi bi-bag-heart-fill me-2"></i>@ViewData["Title"]
    </h2>

    @if (!Model.Orders.Any())
    {
        <div class="card border-0 shadow-sm p-5 text-center" style="border-radius: 20px;">
            <p class="fs-5 text-secondary">Bạn chưa có đơn hàng nào ngọt ngào ở đây cả. <br /> Hãy khám phá các loại bánh ngay nhé!</p>
            <div class="mt-3">
                <a href="/" class="btn btn-lg text-white" style="background-color: #d81b60; border-radius: 12px; font-weight: bold;">Đi đến cửa hàng</a>
            </div>
        </div>
    }
    else
    {
        <div class="list-group">
            @foreach (var order in Model.Orders)
            {
                <div class="card border-0 shadow-sm mb-4" style="border-radius: 20px; overflow: hidden; border-left: 5px solid #d81b60 !important;">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div>
                                <h5 class="fw-bold mb-1" style="color: #ad1457;">Đơn hàng #@order.OrderId</h5>
                                <div class="text-secondary small">
                                    <i class="bi bi-calendar3 me-1"></i> Ngày: @order.OrderDate.ToLocalTime().ToString("g")
                                </div>
                            </div>
                            <div class="text-end">
                                <span class="badge rounded-pill px-3 py-2 mb-2" style="background-color: #fce4ec; color: #d81b60;">
                                    @order.Status
                                </span>
                                <div class="h5 fw-bold" style="color: #d81b60;">
                                    Tổng: @(order.TotalPrice.ToString("C0", new CultureInfo("vi-VN")))
                                </div>
                            </div>
                        </div>

                        <hr style="border-top: 1px dashed #f06292;" />
                        
                        <h6 class="fw-bold mb-3" style="color: #ad1457;"><i class="bi bi-list-check me-2"></i>Chi tiết sản phẩm</h6>
                        
                        <div class="table-responsive">
                            <table class="table table-hover align-middle" style="border-radius: 12px;">
                                <thead style="background-color: #fff1f6; color: #ad1457;">
                                    <tr>
                                        <th class="border-0">Sản phẩm</th>
                                        <th class="border-0 text-center">Số lượng</th>
                                        <th class="border-0 text-end">Giá</th>
                                        <th class="border-0 text-end">Tổng</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var d in order.OrderDetails)
                                    {
                                        <tr>
                                            <td class="fw-medium">@(d.Product?.ProductName ?? "(Đã xóa)")</td>
                                            <td class="text-center">x @d.Quantity</td>
                                            <td class="text-end text-secondary small">@(d.Price.ToString("C0", new CultureInfo("vi-VN")))</td>
                                            <td class="text-end fw-bold" style="color: #d81b60;">@((d.Price * d.Quantity).ToString("C0", new CultureInfo("vi-VN")))</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    /* Bo góc cho bảng sản phẩm */
    .table-responsive {
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #fce4ec;
    }
    /* Hiệu ứng khi di chuột qua từng hàng bánh */
    .table-hover tbody tr:hover {
        background-color: #fff8fa;
    }
</style>