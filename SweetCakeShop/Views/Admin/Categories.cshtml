@model IEnumerable<SweetCakeShop.Models.Category>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý danh mục";
    var stt = 0;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0 text-white">Quản lý Danh mục</h3>
</div>

<div class="container-fluid px-0">
    <div class="row g-4">
        <!-- Form thêm danh mục -->
        <div class="col-12 col-lg-4">
            <div class="card h-100">
                <div class="card-header">
                    <h5 class="mb-0 text-white font-playfair"><i class="bi bi-plus-circle me-2 text-primary"></i>Thêm danh mục</h5>
                </div>
                <div class="card-body">
                    <form asp-action="CreateCategory" asp-controller="Admin" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-4">
                            <label class="form-label">Tên danh mục <span class="text-danger">*</span></label>
                            <input type="text" name="categoryName" class="form-control" maxlength="100" placeholder="VD: Bánh sinh nhật" required />
                        </div>
                        <button type="submit" class="btn btn-primary w-100 py-2"><i class="bi bi-bookmark-plus me-2"></i>Tạo danh mục mới</button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Danh sách danh mục -->
        <div class="col-12 col-lg-8">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 text-white font-playfair"><i class="bi bi-list-ul me-2"></i>Danh sách hiện có</h5>
                    <span class="badge text-bg-secondary">Tổng: @Model.Count()</span>
                </div>
                <div class="card-body p-0">
                    @if (TempData["Success"] is string success)
                    {
                        <div class="alert alert-success d-flex align-items-center m-3 mb-0 py-2 px-3">
                            <i class="bi bi-check-circle-fill me-2 fs-5"></i> @success
                        </div>
                    }
                    @if (TempData["Error"] is string error)
                    {
                        <div class="alert alert-danger d-flex align-items-center m-3 mb-0 py-2 px-3">
                            <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i> @error
                        </div>
                    }

                    <div class="table-responsive mt-3">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th style="width: 80px;" class="text-center">#</th>
                                    <th>Tên danh mục</th>
                                    <th class="text-end" style="width: 220px; padding-right: 1.5rem;">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    stt++;
                                    <tr>
                                        <td class="text-center text-muted">@stt</td>
                                        <td>
                                            <form asp-action="UpdateCategory" asp-controller="Admin" method="post" class="d-flex gap-2">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="categoryId" value="@item.CategoryId" />
                                                <input type="text" name="categoryName" value="@item.CategoryName" class="form-control form-control-sm bg-dark text-white border-secondary" required />
                                                <button type="submit" class="btn btn-sm btn-outline-primary px-3" title="Cập nhật"><i class="bi bi-check2"></i></button>
                                            </form>
                                        </td>
                                        <td class="text-end" style="padding-right: 1.5rem;">
                                            <form asp-action="DeleteCategory" asp-controller="Admin" method="post" class="d-inline"
                                                  onsubmit="return confirm('Bạn có chắc muốn xóa danh mục này?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="categoryId" value="@item.CategoryId" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger px-3">
                                                    <i class="bi bi-trash3 me-1"></i> Xóa
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (!Model.Any())
                    {
                        <div class="text-center text-muted py-5">
                            <i class="bi bi-tags fs-1 d-block mb-3 opacity-50"></i>
                            <span>Chưa có danh mục nào. Hãy tạo một danh mục mới.</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>