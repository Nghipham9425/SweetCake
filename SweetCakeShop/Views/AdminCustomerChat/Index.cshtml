@model SweetCakeShop.Models.ViewModels.AdminCustomerChatIndexViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Chat khách hàng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">Chat khách hàng</h4>
        <div class="text-muted">Xem hội thoại AI và phản hồi khách khi họ cần CSKH.</div>
    </div>
    <a asp-controller="AdminDashboard" asp-action="Index" class="btn btn-outline-secondary btn-sm">Dashboard</a>
</div>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success py-2">@success</div>
}

<div class="row g-3">
    <div class="col-lg-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white fw-semibold">Cuộc hội thoại</div>
            <div class="list-group list-group-flush">
                @foreach (var thread in Model.Threads)
                {
                    var active = Model.SelectedThread?.ThreadKey == thread.ThreadKey;
                    <a asp-action="Index" asp-route-threadKey="@thread.ThreadKey"
                       class="list-group-item list-group-item-action @(active ? "active" : "")">
                        <div class="d-flex justify-content-between gap-2">
                            <strong>@thread.CustomerLabel</strong>
                            <small>@thread.LastMessageAt.ToLocalTime().ToString("dd/MM HH:mm")</small>
                        </div>
                        <div class="small text-truncate">@thread.LastMessage</div>
                        <div class="mt-1">
                            <span class="badge text-bg-secondary">@thread.MessageCount tin</span>
                            @if (thread.NeedsSupport)
                            {
                                <span class="badge text-bg-warning">Cần CSKH</span>
                            }
                        </div>
                    </a>
                }
            </div>
            @if (!Model.Threads.Any())
            {
                <div class="text-muted text-center py-4">Chưa có hội thoại khách hàng.</div>
            }
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white fw-semibold">
                @(Model.SelectedThread?.CustomerLabel ?? "Chưa chọn hội thoại")
            </div>
            <div class="card-body" style="min-height: 420px; max-height: 560px; overflow-y: auto;">
                @foreach (var message in Model.Messages)
                {
                    var isUser = message.Sender == "user";
                    var isAdmin = message.Sender == "admin";
                    <div class="mb-3 d-flex @(isUser ? "justify-content-start" : "justify-content-end")">
                        <div class="p-3 rounded-3 @(isUser ? "bg-light" : isAdmin ? "bg-primary text-white" : "bg-success-subtle")" style="max-width: 78%;">
                            <div class="small mb-1 opacity-75">
                                @(isUser ? "Khách" : isAdmin ? "CSKH" : "AI")
                                · @message.CreatedAt.ToLocalTime().ToString("dd/MM HH:mm")
                            </div>
                            <div style="white-space: pre-wrap;">@message.Content</div>
                        </div>
                    </div>
                }

                @if (!Model.Messages.Any())
                {
                    <div class="text-muted text-center py-5">Chọn một hội thoại để xem nội dung.</div>
                }
            </div>

            @if (Model.SelectedThread != null)
            {
                <div class="card-footer bg-white">
                    <form asp-action="Reply" method="post" class="d-flex gap-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="threadKey" value="@Model.SelectedThread.ThreadKey" />
                        <input name="message" class="form-control" maxlength="2000" placeholder="Nhập phản hồi CSKH..." required />
                        <button class="btn btn-primary" type="submit">
                            <i class="bi bi-send-fill"></i>
                        </button>
                    </form>
                </div>
            }
        </div>
    </div>
</div>
