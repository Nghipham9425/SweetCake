@model SweetCakeShop.Models.ViewModels.HomeViewModel

@{
    ViewData["Title"] = "Home Page";
}

<div class="container-fluid px-lg-5 mt-4">
    <div id="bannerCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="2000" style="max-height: 400px;">

        <div class="carousel-inner rounded">

            <div class="carousel-item active">
                <img src="~/images/banner1.png" class="d-block w-100 rounded" style="max-height: 400px; width: 100%; object-fit: contain;" />
            </div>

            <div class="carousel-item">
                <img src="~/images/banner2.png" class="d-block w-100 rounded" style="max-height: 400px; width: 100%; object-fit: contain;" />
            </div>

            <div class="carousel-item">
                <img src="~/images/banner3.png" class="d-block w-100 rounded" style="max-height: 400px; width: 100%; object-fit: contain;" />
            </div>

        </div>

        <button class="carousel-control-prev"
                type="button"
                data-bs-target="#bannerCarousel"
                data-bs-slide="prev">

            <span class="carousel-control-prev-icon"></span>

        </button>

        <button class="carousel-control-next"
                type="button"
                data-bs-target="#bannerCarousel"
                data-bs-slide="next">

            <span class="carousel-control-next-icon"></span>

        </button>

    </div>
</div>


<div class="container-fluid px-lg-5 mt-5">
    <h3 class="mb-4 fw-bold">Danh mục sản phẩm</h3>

    <div class="row g-3">

        <a asp-controller="Products" asp-action="IndexPro" asp-route-categoryName="Bánh kem" class="col-6 col-md-4 col-lg-2 text-decoration-none">
            <div class="category-card position-relative overflow-hidden rounded shadow-sm">
                <img src="~/images/cate_1.jpg" class="w-100" style="height: 250px; object-fit: cover;" />
                <div class="category-overlay position-absolute top-0 start-0 w-100 h-100 d-flex align-items-end justify-content-center pb-3">
                    <h5 class="text-white fw-bold text-center px-2">Bánh kem</h5>
                </div>
            </div>
        </a>

        <a asp-controller="Products" asp-action="IndexPro" asp-route-categoryName="Bánh bông lan" class="col-6 col-md-4 col-lg-2 text-decoration-none">
            <div class="category-card position-relative overflow-hidden rounded shadow-sm">
                <img src="~/images/cate_2.jpg" class="w-100" style="height: 250px; object-fit: cover;" />
                <div class="category-overlay position-absolute top-0 start-0 w-100 h-100 d-flex align-items-end justify-content-center pb-3">
                    <h5 class="text-white fw-bold text-center px-2">Bánh bông lan</h5>
                </div>
            </div>
        </a>

        <a asp-controller="Products" asp-action="IndexPro" asp-route-categoryName="Bánh quy" class="col-6 col-md-4 col-lg-2 text-decoration-none">
            <div class="category-card position-relative overflow-hidden rounded shadow-sm">
                <img src="~/images/cate_3.jpg" class="w-100" style="height: 250px; object-fit: cover;" />
                <div class="category-overlay position-absolute top-0 start-0 w-100 h-100 d-flex align-items-end justify-content-center pb-3">
                    <h5 class="text-white fw-bold text-center px-2">Bánh quy</h5>
                </div>
            </div>
        </a>

        <a asp-controller="Products" asp-action="IndexPro" asp-route-categoryName="Bánh mì" class="col-6 col-md-4 col-lg-2 text-decoration-none">
            <div class="category-card position-relative overflow-hidden rounded shadow-sm">
                <img src="~/images/cate_4.jpg" class="w-100" style="height: 250px; object-fit: cover;" />
                <div class="category-overlay position-absolute top-0 start-0 w-100 h-100 d-flex align-items-end justify-content-center pb-3">
                    <h5 class="text-white fw-bold text-center px-2">Bánh mì</h5>
                </div>
            </div>
        </a>

        <a asp-controller="Products" asp-action="IndexPro" asp-route-categoryName="Bánh mousse" class="col-6 col-md-4 col-lg-2 text-decoration-none">
            <div class="category-card position-relative overflow-hidden rounded shadow-sm">
                <img src="~/images/cate_5.jpg" class="w-100" style="height: 250px; object-fit: cover;" />
                <div class="category-overlay position-absolute top-0 start-0 w-100 h-100 d-flex align-items-end justify-content-center pb-3">
                    <h5 class="text-white fw-bold text-center px-2">Bánh mousse</h5>
                </div>
            </div>
        </a>

        <a asp-controller="Products" asp-action="IndexPro" asp-route-categoryName="Tiramisu" class="col-6 col-md-4 col-lg-2 text-decoration-none">
            <div class="category-card position-relative overflow-hidden rounded shadow-sm">
                <img src="~/images/cate_6.jpg" class="w-100" style="height: 250px; object-fit: cover;" />
                <div class="category-overlay position-absolute top-0 start-0 w-100 h-100 d-flex align-items-end justify-content-center pb-3">
                    <h5 class="text-white fw-bold text-center px-2">Tiramisu</h5>
                </div>
            </div>
        </a>

    </div>
</div>


<div class="container-fluid px-lg-5 mt-5">
    <h3 class="mb-4 fw-bold text-center">Sản phẩm nổi bật</h3>

    <div class="row g-4 justify-content-center">
        @foreach (var product in Model.FeaturedProducts)
        {
            <div class="col-6 col-md-4 col-lg-2">
                <a class="text-decoration-none text-dark" asp-controller="Products" asp-action="Details" asp-route-id="@product.ProductId">
                    <div class="card h-100 shadow-sm featured-product-card">
                        <div class="featured-product-image">
                            @if (!string.IsNullOrEmpty(product.Image))
                            {
                                <img src="@product.Image" class="card-img-top" alt="@product.ProductName">
                            }
                            else
                            {
                                <img src="~/images/no-image.png" class="card-img-top" alt="No Image">
                            }
                        </div>
                        <div class="card-body text-center">
                            <h6 class="card-title mb-2">@product.ProductName</h6>
                            <p class="mb-0 text-danger fw-bold">@product.Price.ToString("N0") đ</p>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
</div>

<div class="container-fluid px-0 mt-5">
    <section class="contact-banner">
        <div class="contact-banner__overlay">
            <h3 class="fw-bold mb-2">Liên hệ với Sweet Cake Shop</h3>
            <p class="mb-3">Nhắn tin cho chúng tôi qua Facebook hoặc các kênh mạng xã hội khác.</p>
        </div>
    </section>
</div>

<style>
    .category-card {
        cursor: pointer;
        transition: transform 0.3s ease;
    }

        .category-card:hover {
            transform: translateY(-5px);
        }

    .category-overlay {
        background: rgba(0, 0, 0, 0.4);
        transition: background 0.3s ease;
    }

    .category-card:hover .category-overlay {
        background: rgba(0, 0, 0, 0.6);
    }

    .featured-product-card {
        border: none;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .featured-product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 16px rgba(0, 0, 0, 0.12) !important;
        }

    .featured-product-image {
        height: 180px;
        overflow: hidden;
    }

        .featured-product-image img {
            height: 100%;
            object-fit: cover;
        }

    .contact-banner {
        width: 100%;
        min-height: 220px;
        background: url('/images/ft1.jpg') center/cover no-repeat;
        overflow: hidden;
    }

    .contact-banner__overlay {
        min-height: 220px;
        background: rgba(160, 10, 35, 0.8);
        color: #fff;
        text-align: center;
        padding: 48px 16px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }
</style>
