@model SweetCakeShop.Models.ViewModels.PaymentViewModel

@{
    ViewData["Title"] = "Thanh toán";
    var order = Model.Order;
}

<div class="container my-5">
    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h3 class="card-title mb-3">Thanh toán cho đơn hàng <span class="text-pink">#@order?.OrderId</span></h3>

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <h6 class="mb-0">@order?.CustomerName</h6>
                            <small class="text-muted">@order?.CustomerEmail • @order?.CustomerPhone</small>
                        </div>
                        <div class="text-end">
                            <div class="fw-bold fs-5 text-success">@order?.TotalPrice.ToString("N0") ₫</div>
                            <small class="text-muted">Tổng đơn hàng</small>
                        </div>
                    </div>

                    <hr />

                    <h5 class="mt-3 mb-2">Chọn phương thức thanh toán</h5>

                    @if (Model.PaymentResult == null)
                    {
                        <form asp-action="ProcessPayment" method="post" class="row g-3">
                            <input type="hidden" name="orderId" value="@order?.OrderId" />

                            <div class="col-12">
                                <label class="payment-option d-flex p-3 rounded border" for="codOption">
                                    <input class="form-check-input me-3" type="radio" name="method" id="codOption" value="COD" checked />
                                    <div>
                                        <div class="fw-semibold">Thanh toán khi nhận hàng (COD)</div>
                                        <div class="text-muted small">Thanh toán trực tiếp cho nhân viên giao hàng.</div>
                                    </div>
                                </label>
                            </div>

                            <div class="col-12">
                                <label class="payment-option d-flex p-3 rounded border" for="onlineOption">
                                    <input class="form-check-input me-3" type="radio" name="method" id="onlineOption" value="Online" />
                                    <div>
                                        <div class="fw-semibold">Thanh toán online</div>
                                        <div class="text-muted small">Thanh toán bằng thẻ hoặc chuyển khoản. Bạn sẽ được chuyển tới cổng thanh toán an toàn.</div>
                                    </div>
                                </label>
                            </div>

                            <div class="col-12 d-flex gap-2 mt-3">
                                <a asp-action="Checkout" class="btn btn-outline-secondary">Quay lại</a>
                                <button type="submit" class="btn btn-primary">Tiến hành thanh toán</button>
                            </div>
                        </form>
                    }
                    else
                    {
                        <div class="mt-3">
                            <h6>Kết quả tạo thanh toán</h6>

                            @if (Model.PaymentResult.Success)
                            {
                                <div class="alert alert-success d-flex align-items-start">
                                    <div class="me-3">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" class="bi bi-check-circle text-success" viewBox="0 0 16 16">
                                            <path d="M8 15A7 7 0 1 0 8 1a7 7 0 0 0 0 14z"/>
                                            <path d="M10.97 5.97a.235.235 0 0 1 .02.022l-3.992 4.99L5.324 9.43a.25.25 0 0 1 .37-.34l1.237 1.02L10.6 5.9a.25.25 0 0 1 .37-.34z"/>
                                        </svg>
                                    </div>
                                    <div>
                                        <p class="mb-1"><strong>Mã / Session:</strong> @Model.PaymentResult.PaymentCode</p>
                                        @if (!string.IsNullOrEmpty(Model.PaymentResult.PaymentUrl))
                                        {
                                            <p class="mb-1">Bạn sẽ được chuyển tới trang thanh toán an toàn. Nếu trình duyệt không tự chuyển, hãy <a href="@Model.PaymentResult.PaymentUrl" target="_blank" class="fw-bold">bấm vào đây để thanh toán</a>.</p>
                                        }
                                        <p class="mb-0 text-muted">Số tiền: <strong class="text-success">@Model.PaymentResult.Amount.ToString("N0") ₫</strong></p>
                                    </div>
                                </div>

                                <div class="d-flex gap-2">
                                    <a asp-action="Success" asp-route-orderId="@order?.OrderId" class="btn btn-success">Hoàn tất</a>
                                    <a asp-action="Payment" asp-route-orderId="@order?.OrderId" class="btn btn-outline-primary">Quay lại</a>
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-warning">
                                    <p class="mb-1">@Model.PaymentResult.Message</p>
                                    <p class="mb-0"><strong>Mã dự phòng:</strong> @Model.PaymentResult.PaymentCode</p>
                                </div>
                                <div>
                                    <a asp-action="Payment" asp-route-orderId="@order?.OrderId" class="btn btn-outline-primary">Thử lại</a>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm sticky-top" style="top: 100px;">
                <div class="card-body">
                    <h5 class="card-title mb-3">Chi tiết đơn hàng</h5>

                    <ul class="list-group list-group-flush mb-3">
                        @foreach (var d in order?.OrderDetails ?? Enumerable.Empty<SweetCakeShop.Models.OrderDetail>())
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="fw-medium">Sản phẩm ID: @d.ProductId</div>
                                    <small class="text-muted">Số lượng: @d.Quantity</small>
                                </div>
                                <div class="text-end">
                                    <div class="fw-bold">@d.Price.ToString("N0") ₫</div>
                                </div>
                            </li>
                        }
                    </ul>

                    <div class="d-flex justify-content-between align-items-center">
                        <div class="fw-bold">Tổng</div>
                        <div class="fw-bold text-success">@order?.TotalPrice.ToString("N0") ₫</div>
                    </div>

                    <div class="mt-3">
                        <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-secondary w-100">Xem giỏ hàng</a>
                    </div>
                </div>
            </div>

            <!-- Optional: quick actions -->
            <div class="mt-3 text-center">
                <small class="text-muted">Hỗ trợ: <a href="/Home/Contact">Liên hệ</a></small>
            </div>
        </div>
    </div>
</div>

<style>
    .payment-option input[type="radio"] {
        width: 1.25rem;
        height: 1.25rem;
    }
    .payment-option:hover {
        box-shadow: 0 6px 18px rgba(0,0,0,0.06);
        transform: translateY(-2px);
    }
    .text-pink { color: #d81b60; }
    .fw-medium { font-weight: 500; }
    /* responsive tweaks */
   
</style>

<script>
    // Optional: visually highlight selected payment option
    document.addEventListener('DOMContentLoaded', function () {
        const options = document.querySelectorAll('.payment-option');
        options.forEach(opt => {
            const input = opt.querySelector('input[type="radio"]');
            if (!input) return;
            function update() {
                options.forEach(o => o.classList.remove('border-2', 'border-primary'));
                if (input.checked) opt.classList.add('border-2', 'border-primary');
            }
            input.addEventListener('change', update);
            update();
        });
    });
</script>
