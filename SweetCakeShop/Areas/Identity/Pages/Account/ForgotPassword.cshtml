@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Quên mật khẩu?";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card border-0 shadow-lg p-4" style="border-radius: 25px;">
                <div class="card-body">

                    <h1 class="text-center mb-3" style="color: #d81b60; font-weight: bold; font-size: 2rem;">
                        @ViewData["Title"]
                    </h1>

                    <p class="text-center text-secondary mb-4">
                        Nhập email của bạn để nhận liên kết đặt lại mật khẩu.
                    </p>
                    <hr />

                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                        <div class="form-floating mb-4">
                            <input asp-for="Input.Email" class="form-control" style="border-radius: 12px;" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <label asp-for="Input.Email" class="form-label">Địa chỉ Email của bạn</label>
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="w-100 btn btn-lg text-white shadow-sm"
                                style="background-color: #d81b60; border-radius: 12px; font-weight: bold; padding: 12px;">
                            Gửi yêu cầu đặt lại
                        </button>
                    </form>

                    <div class="text-center mt-4">
                        <a asp-page="./Login" class="text-decoration-none fw-bold" style="color: #d81b60;">
                            <i class="bi bi-arrow-left"></i> Quay lại Đăng nhập
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}