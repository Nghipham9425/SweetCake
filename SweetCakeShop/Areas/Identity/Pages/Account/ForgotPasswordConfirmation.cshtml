@page
@model ForgotPasswordConfirmation
@{
    ViewData["Title"] = "Xác nhận quên mật khẩu";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card border-0 shadow-lg p-5 text-center" style="border-radius: 25px;">
                <div class="card-body">

                    <div class="mb-4">
                        <i class="bi bi-envelope-check" style="font-size: 4rem; color: #d81b60;"></i>
                    </div>

                    <h1 class="mb-3" style="color: #d81b60; font-weight: bold; font-size: 1.8rem;">
                        @ViewData["Title"]
                    </h1>

                    <p class="fs-5" style="color: #ad1457;">
                        Vui lòng kiểm tra email của bạn để thực hiện đặt lại mật khẩu.
                    </p>

                    <hr class="my-4" style="border-top: 2px solid #f8bbd0; opacity: 0.5;" />

                    <div class="mt-4">
                        <a asp-page="./Login" class="btn btn-lg text-white w-100 shadow-sm"
                           style="background-color: #d81b60; border-radius: 12px; font-weight: bold;">
                            Quay lại Đăng nhập
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>