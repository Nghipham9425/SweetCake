@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager

<ul class="navbar-nav align-items-center">
    <li class="nav-item dropdown custom-user-nav">
        @if (SignInManager.IsSignedIn(User))
        {
            <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="userMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                <span class="user-name-text">@User.Identity?.Name</span>
            </a>
        }
        else
        {
            <a class="nav-link p-0" href="#" id="loginMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                <img src="~/images/user-icon.png" alt="Login" style="width: 32px; height: 32px; object-fit: contain;" />
            </a>
        }

        <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="userMenu">
            @if (SignInManager.IsSignedIn(User))
            {
                <li>
                    <a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index">
                        <i class="bi bi-person-gear me-2"></i>Hồ sơ cá nhân
                    </a>
                </li>
                <li><hr class="dropdown-divider"></li>
                <li>
                    <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                        <button type="submit" class="dropdown-item text-danger w-100">
                            <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                        </button>
                    </form>
                </li>
            }
            else
            {
                <li>
                    <a class="dropdown-item" asp-area="Identity" asp-page="/Account/Login">Đăng nhập</a>
                </li>
                <li>
                    <a class="dropdown-item" asp-area="Identity" asp-page="/Account/Register">Đăng ký</a>
                </li>
            }
        </ul>
    </li>
</ul>
@if (SignInManager.IsSignedIn(User) && TempData["LoginSuccess"] != null)
{
    <script>
        // Đợi trang load xong rồi mới hiện thông báo
        document.addEventListener("DOMContentLoaded", function() {
            Swal.fire({
                toast: true,
                position: 'top-end', // Hiện ở góc trên bên phải
                icon: 'success',
                title: 'Chào mừng bạn trở lại!',
                text: 'Bạn đã đăng nhập thành công vào SweetCake.',
                showConfirmButton: false, // Không hiện nút OK
                timer: 3000,             // Tự đóng sau 3 giây
                timerProgressBar: true,   // Hiện thanh chạy thời gian
                color: '#d81b60',        // Màu chữ hồng đậm của shop
                iconColor: '#d81b60'      // Màu icon hồng
            });
        });
    </script>
}