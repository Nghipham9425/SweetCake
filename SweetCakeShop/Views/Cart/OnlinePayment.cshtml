@model SweetCakeShop.Models.ViewModels.PaymentViewModel

@{
    ViewData["Title"] = "Thanh toán online";
    var order = Model.Order;
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 text-center">
            <h2 class="mb-4">Thanh toán đơn hàng #@order?.OrderId</h2>

            <p class="lead">Số tiền: <strong>@order?.TotalPrice.ToString("N0") ₫</strong></p>
            <p class="text-muted">Quý khách vui lòng quét mã hoặc chuyển khoản theo thông tin bên dưới. Sau khi thanh toán, bấm nút "Tôi đã thanh toán".</p>

            <div class="my-4 d-flex justify-content-center">
                <!-- Replace this image with your payment image (QR / bank transfer slip) -->
                <img src="~/images/payment-qrcode.png" alt="Payment QR / image" class="img-fluid" style="max-width:360px; border: 1px solid #e9e9e9; padding: 12px; border-radius: 8px;" />
            </div>

            <form asp-action="ConfirmOnlinePayment" method="post">
                <input type="hidden" name="orderId" value="@order?.OrderId" />
                <div class="d-flex justify-content-center gap-2">
                    <a asp-action="Payment" asp-route-orderId="@order?.OrderId" class="btn btn-outline-secondary">Quay lại phương thức thanh toán</a>
                    <button type="submit" class="btn btn-success">Tôi đã thanh toán</button>
                </div>
            </form>

            <div class="mt-4 text-muted small">
                <p>Bạn sẽ cần chờ xác nhận từ hệ thống sau khi đã chuyển khoản.</p>
            </div>
        </div>
    </div>
</div>
