@using SweetCakeShop.Services
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SweetCakeShop</title>
    
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SweetCakeShop.styles.css" asp-append-version="true" />
</head>

<body class="d-flex flex-column min-vh-100">
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg sweet-navbar">
        <div class="container">
            <!-- Logo -->
            <a class="navbar-brand fw-bold ms-lg-2" asp-area="" asp-controller="Home" asp-action="Index">
                <img src="~/images/logo.png" alt="SweetCakeShop" class="navbar-logo" />
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Menu Content -->
            <div class="collapse navbar-collapse" id="navbarContent">
                <div class="ms-auto d-flex flex-column flex-lg-row align-items-lg-center">
                    
                    <!-- Navigation Links -->
                    <ul class="navbar-nav mb-3 mb-lg-0 me-lg-4">
                        <li class="nav-item">
                            <a class="nav-link px-3 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")" asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Products" ? "active" : "")" asp-area="" asp-controller="Products" asp-action="IndexPro">Sản phẩm</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 @(ViewContext.RouteData.Values["action"]?.ToString() == "Contact" ? "active" : "")" asp-area="" asp-controller="Home" asp-action="Contact">Liên hệ</a>
                        </li>
                        @if (User.IsInRole(SweetCakeShop.Constants.Roles.Admin.ToString()))
                        {
                            <li class="nav-item">
                                <a class="nav-link px-3 text-pink" asp-area="" asp-controller="AdminDashboard" asp-action="Index">
                                    <i class="bi bi-shield-lock me-1"></i>Admin
                                </a>
                            </li>
                        }
                        @if (User.IsInRole(SweetCakeShop.Constants.Roles.Shipper.ToString()))
                        {
                            <li class="nav-item">
                                <a class="nav-link px-3 text-pink" asp-area="" asp-controller="Shipper" asp-action="Orders">
                                    <i class="bi bi-truck me-1"></i>Giao hàng
                                </a>
                            </li>
                        }
                    </ul>

                    <!-- Search, Cart, Login Group -->
                    <div class="d-flex align-items-center gap-3">
                        <!-- Search Bar -->
                        <form class="sweet-search me-2 d-none d-md-block" method="get" asp-area="" asp-controller="Products" asp-action="IndexPro">
                            <input type="search" name="searchTerm" value="@Context.Request.Query["searchTerm"]" placeholder="Tìm kiếm bánh ngọt..." aria-label="Search">
                            <button class="search-btn" type="submit">
                                <i class="bi bi-search"></i>
                            </button>
                        </form>

                        <!-- Cart Icon -->
                        <a class="cart-icon-wrapper" asp-area="" asp-controller="Cart" asp-action="Index" aria-label="Giỏ hàng">
                            <i class="bi bi-bag navbar-action-icon"></i>
                            @await Component.InvokeAsync("CartBadge")
                        </a>

                        <!-- Login Partial -->
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container-fluid px-0 flex-grow-1">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <!-- Footer -->
    <footer class="sweet-footer mt-auto">
        <div class="container">
            <div class="row">
                <!-- Brand Info -->
                <div class="col-lg-4 mb-4 mb-lg-0 pe-lg-5">
                    <a href="/" class="footer-brand text-decoration-none">SweetCakeShop</a>
                    <p>
                        Mang đến những chiếc bánh ngọt ngào nhất cho những khoảnh khắc đáng nhớ của bạn.
                        Chúng tôi tự hào với công thức độc quyền và nguyên liệu cao cấp nhất.
                    </p>
                    <div class="footer-social mt-4">
                        <a href="#"><i class="bi bi-instagram"></i></a>
                        <a href="#"><i class="bi bi-facebook"></i></a>
                        <a href="#"><i class="bi bi-tiktok"></i></a>
                    </div>
                </div>

                <!-- Quick Links -->
                <div class="col-lg-2 col-md-4 mb-4 mb-md-0">
                    <h6>Khám phá</h6>
                    <ul>
                        <li><a href="/">Trang chủ</a></li>
                        <li><a href="/Products">Sản phẩm mới</a></li>
                        <li><a href="/Products">Bán chạy nhất</a></li>
                        <li><a href="/Home/Contact">Liên hệ</a></li>
                    </ul>
                </div>

                <!-- Support -->
                <div class="col-lg-3 col-md-4 mb-4 mb-md-0">
                    <h6>Chăm sóc khách hàng</h6>
                    <ul>
                        <li><a href="#">Chính sách giao hàng</a></li>
                        <li><a href="#">Đổi trả & Hoàn tiền</a></li>
                        <li><a href="#">Hướng dẫn thanh toán</a></li>
                        <li><a href="/Cart">Tra cứu đơn hàng</a></li>
                    </ul>
                </div>

                <!-- Contact -->
                <div class="col-lg-3 col-md-4">
                    <h6>Liên hệ</h6>
                    <ul class="mb-0">
                        <li class="d-flex gap-2 text-white-50 align-items-start mb-3">
                            <i class="bi bi-geo-alt mt-1 text-pink-light"></i>
                            <span>123 Đường Bánh Ngọt, Quận 1, TP. Hồ Chí Minh</span>
                        </li>
                        <li class="d-flex gap-2 text-white-50 align-items-center mb-3">
                            <i class="bi bi-telephone text-pink-light"></i>
                            <span>1900 6789</span>
                        </li>
                        <li class="d-flex gap-2 text-white-50 align-items-center">
                            <i class="bi bi-envelope text-pink-light"></i>
                            <span>hello@sweetcakeshop.com</span>
                        </li>
                    </ul>
                </div>
            </div>

            <hr>
            
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                    <span class="copyright">&copy; 2026 SweetCakeShop. All rights reserved.</span>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <img src="~/images/payment-methods.png" alt="Payment Methods" height="24" style="opacity: 0.5;" onerror="this.style.display='none'">
                </div>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @await Html.PartialAsync("_Toast")

    <!-- Client Helpers -->
    <script>
        function updateCartBadge() {
            fetch('/Cart/Count')
                .then(r => r.json())
                .then(j => {
                    const b = document.querySelector('.cart-badge-count');
                    if (b) {
                        b.textContent = j.count;
                        // Trigger animation
                        b.style.animation = 'none';
                        b.offsetHeight; /* trigger reflow */
                        b.style.animation = null; 
                    }
                });
        }

        function addToCartAjax(productId, quantity = 1) {
            const body = new URLSearchParams();
            body.append('id', productId);
            body.append('quantity', quantity);

            fetch('/Cart/Add', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: body.toString()
            })
            .then(r => r.json())
            .then(data => {
                if (data?.success) {
                    showToast(data.message, 'success');
                    updateCartBadge();
                } else {
                    showToast('Không thể thêm vào giỏ hàng.', 'danger');
                }
            })
            .catch(() => showToast('Lỗi thêm vào giỏ hàng.', 'danger'));
        }

        document.addEventListener('DOMContentLoaded', () => updateCartBadge());
    </script>

    @await Html.PartialAsync("_CustomerChatWidget")
    @RenderSection("Scripts", required: false)
</body>
</html>
