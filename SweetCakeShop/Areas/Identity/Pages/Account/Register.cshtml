@page
@model RegisterModel
@{
    ViewData["Title"] = "Đăng ký tài khoản";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-6">
            <div class="card border-0 shadow-lg p-4" style="border-radius: 25px;">
                <div class="card-body">

                    <h1 class="text-center mb-4" style="color: #d81b60; font-weight: bold; font-size: 2.2rem; white-space: nowrap;">
                        Gia nhập thế giới bánh ngọt
                    </h1>

                    <h2 class="text-center h5 text-secondary mb-4">Tạo tài khoản mới để bắt đầu</h2>
                    <hr />

                    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                        <div class="form-group mb-3">
                            <label asp-for="Input.Email" class="form-label fw-bold" style="color: #444;">Địa chỉ Email *</label>
                            <input asp-for="Input.Email" class="form-control p-3" style="border-radius: 12px;" placeholder="name@example.com" />
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Input.Password" class="form-label fw-bold" style="color: #444;">Mật khẩu *</label>
                            <div class="password-toggle-wrap">
                                <input asp-for="Input.Password" class="form-control p-3" style="border-radius: 12px;" placeholder="Nhập mật khẩu của bạn" autocomplete="new-password" />
                                <button type="button" class="password-toggle-btn" aria-label="Hiện mật khẩu">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Input.ConfirmPassword" class="form-label fw-bold" style="color: #444;">Xác nhận mật khẩu *</label>
                            <div class="password-toggle-wrap">
                                <input asp-for="Input.ConfirmPassword" class="form-control p-3" style="border-radius: 12px;" placeholder="Nhập lại mật khẩu" autocomplete="new-password" />
                                <button type="button" class="password-toggle-btn" aria-label="Hiện mật khẩu">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <button id="registerSubmit" type="submit" class="w-100 btn btn-lg text-white mb-3 shadow-sm" style="background-color: #d81b60; border-radius: 12px; font-weight: bold; padding: 12px;">
                            Đăng ký ngay
                        </button>

                        <div class="text-center mt-3">
                            <p>Đã có tài khoản? <a asp-page="./Login" class="text-decoration-none fw-bold" style="color: #d81b60;">Đăng nhập tại đây</a></p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelectorAll('.password-toggle-btn').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var input = btn.closest('.password-toggle-wrap').querySelector('input');
                var icon = btn.querySelector('i');
                var show = input.type === 'password';
                input.type = show ? 'text' : 'password';
                icon.classList.toggle('bi-eye', !show);
                icon.classList.toggle('bi-eye-slash', show);
                btn.setAttribute('aria-label', show ? 'Ẩn mật khẩu' : 'Hiện mật khẩu');
            });
        });
    </script>
}