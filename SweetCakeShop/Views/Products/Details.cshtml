@model SweetCakeShop.Models.Product

@{
    ViewData["Title"] = Model.ProductName;
}

<div class="container-fluid px-lg-5 mt-4">
    <div class="row g-4">
        <div class="col-lg-6">
            <div class="border rounded overflow-hidden bg-white">
                @if (!string.IsNullOrEmpty(Model.Image))
                {
                    <img src="@Model.Image" class="w-100" alt="@Model.ProductName" style="max-height: 520px; object-fit: contain;" />
                }
                else
                {
                    <img src="~/images/no-image.png" class="w-100" alt="No Image" style="max-height: 520px; object-fit: contain;" />
                }
            </div>
        </div>
        <div class="col-lg-6">
            <div class="mb-2 text-muted">
                <a class="text-decoration-none text-muted" asp-controller="Home" asp-action="Index">Trang chủ</a>
                <span class="mx-1">›</span>
                <a class="text-decoration-none text-muted" asp-controller="Products" asp-action="Index">Menu</a>
                <span class="mx-1">›</span>
                <span>@Model.Category?.CategoryName</span>
            </div>

            <h2 class="fw-bold mb-3">@Model.ProductName</h2>

            <p class="text-muted mb-3">
                @Model.Description
            </p>

            <div class="mb-4">
                <span class="text-success fw-bold fs-3">@Model.Price.ToString("N0") đ</span>
            </div>

            <div class="d-flex align-items-center mb-4">
                <label class="me-3 fw-semibold">Số lượng:</label>
                <input type="number" class="form-control" style="width: 120px;" min="1" value="1" />
            </div>

            <div class="d-flex gap-3">
                <button class="btn btn-pink px-4 py-2">
                    Thêm vào giỏ hàng
                </button>
                <button class="btn btn-outline-danger px-4 py-2">
                    Mua ngay
                </button>
            </div>
        </div>
    </div>
</div>
