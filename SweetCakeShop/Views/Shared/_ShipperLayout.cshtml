<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SweetCake Shipper</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        body {
            background: #f5f7fb;
            color: #172033;
        }

        .shipper-shell {
            min-height: 100vh;
        }

        .shipper-topbar {
            background: #172033;
            color: #fff;
            position: sticky;
            top: 0;
            z-index: 1020;
            box-shadow: 0 8px 24px rgba(23, 32, 51, 0.14);
        }

        .shipper-brand {
            color: #fff;
            font-weight: 800;
            text-decoration: none;
            letter-spacing: 0;
        }

        .shipper-brand:hover {
            color: #fff;
        }

        .shipper-main {
            padding: 24px 0 40px;
        }

        .shipper-card {
            border-radius: 8px;
            border: 1px solid #e6eaf2;
            box-shadow: 0 10px 30px rgba(23, 32, 51, 0.07);
        }

        .shipper-action {
            min-height: 42px;
        }
    </style>
</head>
<body>
    <div class="shipper-shell">
        <header class="shipper-topbar">
            <div class="container py-3 d-flex align-items-center justify-content-between gap-3">
                <a class="shipper-brand d-flex align-items-center gap-2" asp-controller="Shipper" asp-action="Orders">
                    <i class="bi bi-truck"></i>
                    <span>SweetCake Delivery</span>
                </a>

                <div class="d-flex align-items-center gap-3">
                    <span class="small text-white-50 d-none d-sm-inline">@User.Identity?.Name</span>
                    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
                        <button type="submit" class="btn btn-sm btn-outline-light">
                            <i class="bi bi-box-arrow-right me-1"></i>Đăng xuất
                        </button>
                    </form>
                </div>
            </div>
        </header>

        <main class="shipper-main">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
