@model SweetCakeShop.Models.ViewModels.CartViewModel

@{
    ViewData["Title"] = "Giỏ hàng";
}

<div class="container my-5">
    <h2 class="text-center mb-4">Giỏ hàng của bạn</h2>

    @if (Model.Items.Any())
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="list-group">
                    @Html.AntiForgeryToken()
                    @foreach (var item in Model.Items)
                    {
                        <div class="list-group-item p-3 mb-3 rounded shadow-sm cart-item" data-product-id="@item.ProductId">
                            <div class="row align-items-center g-2">
                                <div class="col-3 col-md-2">
                                    <img src="@item.Image" alt="@item.ProductName" class="img-fluid rounded" style="max-height:80px; object-fit:cover;" />
                                </div>
                                <div class="col-9 col-md-6">
                                    <a asp-controller="Products" asp-action="Details" asp-route-id="@item.ProductId" class="text-decoration-none text-dark">
                                        <h6 class="mb-1 text-truncate">@item.ProductName</h6>
                                    </a>
                                    <div class="text-muted small">@item.Price.ToString("N0") ₫ / chiếc</div>
                                </div>

                                <div class="col-12 col-md-4 d-flex justify-content-between align-items-center mt-3 mt-md-0">
                                    <div class="input-group input-group-sm quantity-group" style="width:150px;">
                                        <button class="btn btn-outline-secondary btn-sm decrement" type="button" aria-label="Decrease">−</button>
                                        <input type="number" class="form-control text-center qty-input" value="@item.Quantity" min="1" data-product-id="@item.ProductId" />
                                        <button class="btn btn-outline-secondary btn-sm increment" type="button" aria-label="Increase">+</button>
                                    </div>

                                    <div class="text-end ms-3">
                                        <div class="fw-bold">@item.Subtotal.ToString("N0") ₫</div>
                                        <button class="btn btn-link text-danger p-0 mt-1 remove-btn" type="button" data-product-id="@item.ProductId">Xóa</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-sm sticky-top" style="top:100px;">
                    <div class="card-body">
                        <h5 class="card-title">Tóm tắt đơn hàng</h5>

                        <div class="d-flex justify-content-between">
                            <div>Số mặt hàng</div>
                            <div class="fw-bold">@Model.Items.Sum(i => i.Quantity)</div>
                        </div>
                        <div class="d-flex justify-content-between mt-2">
                            <div>Tạm tính</div>
                            <div class="fw-bold">@Model.TotalAmount.ToString("N0") ₫</div>
                        </div>

                        <hr />

                        <div class="mb-3">
                            <label class="form-label small">Mã giảm giá</label>
                            <div class="input-group">
                                <input id="coupon-code" class="form-control form-control-sm" placeholder="Nhập mã (nếu có)" />
                                <button id="apply-coupon" class="btn btn-sm btn-outline-secondary" type="button">Áp dụng</button>
                            </div>
                            <small id="coupon-feedback" class="text-success small d-none"></small>
                        </div>

                        <div class="d-grid gap-2">
                            <a asp-controller="Cart" asp-action="Checkout" class="btn btn-pink btn-lg">Tiến hành đặt hàng</a>
                            <a asp-controller="Products" asp-action="IndexPro" class="btn btn-outline-secondary">Tiếp tục mua sắm</a>
                        </div>
                    </div>
                </div>

                <div class="mt-3 text-muted small">
                    <p class="mb-1"><strong>Ghi chú:</strong></p>
                    <p class="mb-0">Miễn phí giao hàng cho đơn hàng trên 500,000₫. Thông tin vận chuyển sẽ được yêu cầu ở bước thanh toán.</p>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center">
            Giỏ hàng của bạn đang trống. <a asp-controller="Home" asp-action="Index">Tiếp tục mua sắm</a>
        </div>
    }
</div>

<style>
    .cart-item { transition: transform .08s ease, box-shadow .08s ease; }
    .cart-item:hover { transform: translateY(-3px); box-shadow: 0 6px 18px rgba(0,0,0,0.06); }
    .quantity-group .btn { width: 38px; }
   /*  media (max-width: 767.98px) {
        .sticky-top { position: static !important; top: auto !important; }
    } */
</style>

@section Scripts {
    <script>
        // helper: get antiforgery token rendered on the page
        function getAntiForgeryToken() {
            const tokenField = document.querySelector('input[name="__RequestVerificationToken"]');
            return tokenField ? tokenField.value : '';
        }

        // POST helper using form-encoded body
        async function postForm(url, data) {
            const token = getAntiForgeryToken();
            if (token) data.__RequestVerificationToken = token;

            const body = new URLSearchParams();
            for (const k in data) body.append(k, data[k]);

            const res = await fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: body.toString()
            });
            return res;
        }

        // debounce helper
        function debounce(func, wait) {
            let timeout;
            return (...args) => {
                clearTimeout(timeout);
                timeout = setTimeout(() => func.apply(this, args), wait);
            };
        }

        // update quantity (AJAX). Reloads page on success to reflect totals.
        async function updateQuantity(productId, quantity) {
            try {
                const res = await postForm('/Cart/Update', { productId: productId, quantity: quantity });
                if (res.ok) {
                    // update badge and reload to refresh totals
                    updateCartBadge();
                    location.reload();
                } else {
                    showToast('Không thể cập nhật số lượng.', 'danger');
                }
            } catch {
                showToast('Lỗi khi cập nhật số lượng.', 'danger');
            }
        }

        // remove item (AJAX) with confirm
        async function removeItem(productId) {
            if (!confirm('Bạn có chắc muốn xóa sản phẩm khỏi giỏ hàng?')) return;
            try {
                const res = await postForm('/Cart/Remove', { productId: productId });
                if (res.ok) {
                    updateCartBadge();
                    location.reload();
                } else {
                    showToast('Không thể xóa sản phẩm.', 'danger');
                }
            } catch {
                showToast('Lỗi khi xóa sản phẩm.', 'danger');
            }
        }

        // wire up steppers and text inputs
        document.addEventListener('DOMContentLoaded', function () {
            // plus / minus buttons
            document.querySelectorAll('.cart-item').forEach(function (el) {
                const productId = el.getAttribute('data-product-id');

                const decrement = el.querySelector('.decrement');
                const increment = el.querySelector('.increment');
                const qtyInput = el.querySelector('.qty-input');

                const debouncedUpdate = debounce(function (val) {
                    updateQuantity(productId, Math.max(1, parseInt(val || 1)));
                }, 500);

                decrement?.addEventListener('click', function () {
                    const val = Math.max(1, parseInt(qtyInput.value || '1') - 1);
                    qtyInput.value = val;
                    debouncedUpdate(val);
                });

                increment?.addEventListener('click', function () {
                    const val = Math.max(1, parseInt(qtyInput.value || '1') + 1);
                    qtyInput.value = val;
                    debouncedUpdate(val);
                });

                qtyInput?.addEventListener('input', function (e) {
                    const v = Math.max(1, parseInt(qtyInput.value || '1'));
                    qtyInput.value = v;
                    debouncedUpdate(v);
                });

                // remove button
                const removeBtn = el.querySelector('.remove-btn');
                removeBtn?.addEventListener('click', function () {
                    removeItem(productId);
                });
            });

            // coupon (simple UI only)
            document.getElementById('apply-coupon')?.addEventListener('click', function () {
                const code = document.getElementById('coupon-code')?.value?.trim();
                if (!code) {
                    showToast('Vui lòng nhập mã giảm giá.', 'warning');
                    return;
                }
                // placeholder — implement server validation later
                document.getElementById('coupon-feedback').classList.remove('d-none');
                document.getElementById('coupon-feedback').textContent = 'Mã "' + code + '" đã được áp dụng (demo).';
                showToast('Mã giảm giá đã áp dụng', 'success');
            });
        });
    </script>
}