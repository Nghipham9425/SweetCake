<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SweetCake Admin</title>
    
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/chatbox.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true" />
</head>
<body class="admin-body">
    
    <div class="admin-layout-wrapper">
        <!-- Sidebar -->
        <aside class="admin-sidebar">
            <a class="brand" asp-controller="AdminDashboard" asp-action="Index">
                SweetCake
            </a>
            <span class="admin-subtitle">Admin Console</span>
            
            <nav class="nav flex-column mt-2 flex-grow-1">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminDashboard" ? "active" : "")"
                   asp-controller="AdminDashboard" asp-action="Index">
                   <i class="bi bi-grid-1x2-fill"></i>
                   <span>Tổng quan</span>
                </a>
                
                <a class="nav-link @((ViewContext.RouteData.Values["action"]?.ToString() == "Orders" || ViewContext.RouteData.Values["action"]?.ToString() == "OrderDetails") ? "active" : "")"
                   asp-controller="Admin" asp-action="Orders">
                   <i class="bi bi-bag-check-fill"></i>
                   <span>Đơn hàng</span>
                </a>
                
                <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Products" ? "active" : "")"
                   asp-controller="Admin" asp-action="Products">
                   <i class="bi bi-box-seam-fill"></i>
                   <span>Sản phẩm & Kho</span>
                </a>
                
                <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Categories" ? "active" : "")"
                   asp-controller="Admin" asp-action="Categories">
                   <i class="bi bi-tags-fill"></i>
                   <span>Danh mục</span>
                </a>
                
                <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Ingredients" ? "active" : "")"
                   asp-controller="Admin" asp-action="Ingredients">
                   <i class="bi bi-basket3-fill"></i>
                   <span>Nguyên liệu</span>
                </a>
                
                <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "TopSellingProducts" ? "active" : "")"
                   asp-controller="Admin" asp-action="TopSellingProducts">
                   <i class="bi bi-graph-up-arrow"></i>
                   <span>Bán chạy</span>
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminCustomerBehavior" ? "active" : "")"
                   asp-controller="AdminCustomerBehavior" asp-action="Index">
                   <i class="bi bi-person-lines-fill"></i>
                   <span>Hành vi khách</span>
                </a>

                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminCustomerChat" ? "active" : "")"
                   asp-controller="AdminCustomerChat" asp-action="Index">
                   <i class="bi bi-headset"></i>
                   <span>Chat khách</span>
                </a>
            </nav>

            <a class="nav-link nav-link-home mt-auto" asp-controller="Home" asp-action="Index">
                <i class="bi bi-arrow-left-circle-fill"></i>
                <span>Về trang chủ</span>
            </a>
        </aside>
        
        <!-- Main Content -->
        <main class="admin-main">
            <!-- Header for Mobile (Optional, can be expanded later) -->
            <div class="d-flex d-lg-none justify-content-between align-items-center mb-4">
                <h4 class="mb-0 text-white font-playfair">SweetCake Admin</h4>
            </div>

            <!-- Page Content -->
            <div class="anim-fade-in">
                @RenderBody()
            </div>
        </main>
    </div>

    <!-- Widgets -->
    @await Html.PartialAsync("_AdminChatWidget")

    <!-- Scripts -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
