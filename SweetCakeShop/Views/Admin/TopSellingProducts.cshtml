@model IEnumerable<SweetCakeShop.Models.AdminTopSellingProductViewModel>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Xếp hạng bánh bán chạy";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Xếp hạng bánh bán chạy</h5>
        <span class="badge text-bg-secondary">@Model.Count()</span>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th style="width:90px;">Hạng</th>
                        <th>Tên bánh</th>
                        <th style="width:180px;">SL đã bán</th>
                        <th style="width:220px;">Doanh thu</th>
                        <th style="width:220px;">Số đơn</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @if (item.Rank == 1)
                                {
                                    <span class="badge text-bg-warning">#1</span>
                                }
                                else if (item.Rank == 2)
                                {
                                    <span class="badge text-bg-secondary">#2</span>
                                }
                                else if (item.Rank == 3)
                                {
                                    <span class="badge text-bg-dark">#3</span>
                                }
                                else
                                {
                                    <span>#@item.Rank</span>
                                }
                            </td>
                            <td class="fw-semibold">@item.ProductName</td>
                            <td>@item.SoldQuantity</td>
                            <td>@item.TotalRevenue.ToString("N0") đ</td>
                            <td>@item.ConfirmedOrderCount</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="text-muted">Chưa có dữ liệu đơn hàng ở trạng thái Confirmed.</div>
        }
    </div>
</div>