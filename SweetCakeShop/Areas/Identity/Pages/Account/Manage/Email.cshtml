@page
@model EmailModel
@{
    ViewData["Title"] = "Quản lý Email";
    ViewData["ActivePage"] = ManageNavPages.Email;
}

<h3 class="mb-3" style="color: #ad1457; font-weight: bold;">@ViewData["Title"]</h3>
<partial name="_StatusMessage" for="StatusMessage" />

<div class="row">
    <div class="col-md-8">
        <form id="email-form" method="post">
            <div asp-validation-summary="All" class="text-danger" role="alert"></div>

            @if (Model.IsEmailConfirmed)
            {
                <div class="form-floating mb-3 input-group">
                    <input asp-for="Email" class="form-control" style="border-radius: 12px 0 0 12px; background-color: #f8f9fa;" placeholder="Email hiện tại" disabled />
                    <div class="input-group-append">
                        <span class="h-100 input-group-text text-success font-weight-bold" style="border-radius: 0 12px 12px 0; background-color: #e8f5e9;">✓ Đã xác minh</span>
                    </div>
                    <label asp-for="Email" class="form-label">Email hiện tại</label>
                </div>
            }
            else
            {
                <div class="form-floating mb-3">
                    <input asp-for="Email" class="form-control" style="border-radius: 12px; background-color: #f8f9fa;" placeholder="Email hiện tại" disabled />
                    <label asp-for="Email" class="form-label">Email hiện tại</label>
                    <button id="email-verification" type="submit" asp-page-handler="SendVerificationEmail" class="btn btn-link mt-1" style="color: #d81b60; font-weight: bold; text-decoration: none;">
                        Gửi email xác thực
                    </button>
                </div>
            }

            <div class="form-floating mb-4">
                <input asp-for="Input.NewEmail" class="form-control" style="border-radius: 12px;" autocomplete="email" aria-required="true" placeholder="Nhập email mới" />
                <label asp-for="Input.NewEmail" class="form-label">Địa chỉ Email mới</label>
                <span asp-validation-for="Input.NewEmail" class="text-danger small"></span>
            </div>

            <button id="change-email-button" type="submit" asp-page-handler="ChangeEmail" class="w-100 btn btn-lg text-white shadow-sm"
                    style="background-color: #d81b60; border-radius: 12px; font-weight: bold; padding: 12px;">
                Thay đổi Email
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}