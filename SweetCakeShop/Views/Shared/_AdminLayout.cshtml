<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="bg-light">
    <div class="container-fluid">
        <div class="row min-vh-100">
            <aside class="col-12 col-md-3 col-lg-2 bg-white border-end p-3">
                <h5 class="mb-4">Admin Panel</h5>
                <ul class="nav flex-column gap-1">
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active fw-semibold" : "text-dark")"
                               asp-controller="Home" asp-action="Index">
                            Trang chủ
                        </a>
                        <a class="nav-link @((ViewContext.RouteData.Values["action"]?.ToString() == "Orders" || ViewContext.RouteData.Values["action"]?.ToString() == "OrderDetails") ? "active fw-semibold" : "text-dark")"
                           asp-controller="Admin" asp-action="Orders">
                            Xem Orders
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Categories" ? "active fw-semibold" : "text-dark")"
                           asp-controller="Admin" asp-action="Categories">
                            Danh mục
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Ingredients" ? "active fw-semibold" : "text-dark")"
                               asp-controller="Admin" asp-action="Ingredients">
                            Xem Nguyên liệu tồn kho
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Products" ? "active fw-semibold" : "text-dark")"
                           asp-controller="Admin" asp-action="Products">
                            Xem số lượng bánh có thể làm
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "TopSellingProducts" ? "active fw-semibold" : "text-dark")"
                           asp-controller="Admin" asp-action="TopSellingProducts">
                            Bánh bán chạy nhất
                        </a>
                    </li>
                </ul>
            </aside>

            <main class="col-12 col-md-9 col-lg-10 p-3 p-md-4">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
